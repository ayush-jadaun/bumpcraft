{
  "name": "bumpcraft",
  "version": "1.1.0",
  "description": "A pluggable semantic versioning engine with changelog generation, release policies, and a web dashboard",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "bumpcraft": "./dist/cli/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('dist/dashboard',{recursive:true});fs.copyFileSync('src/dashboard/index.html','dist/dashboard/index.html')\"",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "start": "node dist/api/server.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "semver",
    "semantic-versioning",
    "changelog",
    "release",
    "version-bump",
    "conventional-commits",
    "git",
    "automation",
    "ci",
    "cd"
  ],
  "author": "Ayush Jadaun",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ayush-jadaun/bumpcraft.git"
  },
  "homepage": "https://github.com/ayush-jadaun/bumpcraft#readme",
  "bugs": {
    "url": "https://github.com/ayush-jadaun/bumpcraft/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "express": "^5.2.1",
    "simple-git": "^3.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
